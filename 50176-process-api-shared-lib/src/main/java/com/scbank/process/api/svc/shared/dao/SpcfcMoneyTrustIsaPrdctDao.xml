<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.shared.dao.SpcfcMoneyTrustIsaPrdctDao">

	<select id="selectSpcfcTrustPrdct" parameterType="java.util.List" resultType="com.scbank.process.api.svc.shared.dao.dto.SpcfcTrustPrdctResult">
		SELECT
			PRDCT_NM,
			PRDCT_CD
		FROM
			SPCFC_MONEY_TRUST_ISA_PRDCT
		WHERE
			PRDCT_CD IN
		<foreach collection="trustCodeList" item="item" index="index" open="(" separator=","  close=")">
			#{item}
		</foreach>
		WITH UR
	</select>

</mapper>