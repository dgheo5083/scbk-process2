<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scbank.process.api.svc.shared.dao.IpIntrcptListInfoDao">

    <!-- 해외IP차단여부 -->
	<select id="selectAboardYn" parameterType="com.scbank.process.api.svc.shared.dao.dto.IPInsideAboardParameter" resultType="int">
		SELECT 
			count(*) as cnt 
		FROM IP_INTRCPT_LIST_INFO 
		WHERE #{ipStartAddr}  <![CDATA[>=]]> IP_START_ADDR
		AND #{ipEndAddr} <![CDATA[<=]]> IP_END_ADDR
		WITH UR
	</select>


</mapper>