<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.shared.components.tradinfo.dao.NfTradeInfoDtlDao">

	<!-- 비대면거래관리테이블상세 등록 (asis : NF_TRADINFO_DTL_I_01)-->
	<insert id="insertTradeInfoDetail" parameterType="com.scbank.process.api.svc.shared.components.tradinfo.dao.dto.NonFaceTradeInfoDetailParameter" >
		INSERT INTO NF_TRADINFO_DTL (
			INIT_REGIST_DT,
			CUST_NO,
			TRAD_NO
		) VALUES (
		  CURRENT TIMESTAMP,
		  #{custNo},
		  #{tradNo}
		)
	</insert>
</mapper>