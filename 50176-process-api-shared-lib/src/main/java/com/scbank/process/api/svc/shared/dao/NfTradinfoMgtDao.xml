<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.shared.dao.NfTradinfoMgtDao">
	<select id="selectNfAuthCompleteYn" parameterType="com.scbank.process.api.svc.shared.dao.dto.NfAuthCompleteYnParameter" resultType="com.scbank.process.api.svc.shared.dao.dto.NfAuthCompleteYnResult">
		SELECT
			ID_CARD_CD,
			AUTHNT_IND_CD,
			CDD_REQ_CD,
			DOC_EVDC_CD
		FROM
			NF_TRADINFO_MGT
		WHERE
			CUST_NO=#{custNo} AND TRAD_NO=#{tradNo}
		with ur
	</select>
</mapper>