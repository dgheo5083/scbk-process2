<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.shared.dao.SaleFundInfoDao">
    <select id="selectSaleFundInfoList" parameterType="java.util.List" resultType="com.scbank.process.api.svc.shared.dao.dto.SaleFundInfoResult">
		SELECT
			FUND_KRN_NM as fundKrnNm,
			FUND_ENG_NM as fundEngNm,
			SALE_FUND_CD as saleFundCd  
		FROM
			SALE_FUND_INFO 
		WHERE
			SALE_FUND_CD IN 
			<foreach collection="fundCodeList" item="item" index="index" open="(" separator=","  close=")">
				#{item}
			</foreach>
		WITH UR
	</select>
</mapper>