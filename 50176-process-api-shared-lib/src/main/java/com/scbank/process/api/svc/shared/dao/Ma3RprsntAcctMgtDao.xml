<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.shared.dao.Ma3RprsntAcctMgtDao">

	<select id="selectRepresentAccount" parameterType="java.lang.String" resultType="com.scbank.process.api.svc.shared.dao.dto.RepresentAccountResult">
		SELECT 
			USER_ID,
			MY_RPRSNT_ACCT_1,
			MY_RPRSNT_ACCT_2,
			MY_RPRSNT_ACCT_3,
			MY_RPRSNT_ACCT_4,
			MY_RPRSNT_ACCT_5,
			UPD_TM,
			REGIST_TM
		FROM
			MA3_RPRSNT_ACCT_MGT
		WHERE
			USER_ID = #{userId}
		WITH UR
	</select>

	<!-- 대표계좌 삭제 -->
	<delete id="deleteRepresentAccount" parameterType="java.lang.String">
		DELETE FROM MA3_RPRSNT_ACCT_MGT
		WHERE USER_ID = #{userId}
	</delete>

</mapper>