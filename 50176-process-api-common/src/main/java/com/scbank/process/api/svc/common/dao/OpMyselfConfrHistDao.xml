<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.common.dao.OpMyselfConfrHistDao">

	<!-- 디지털인증서 Backup 사용자 조회 [MA3_LGN.FIDO_BACKUP_CERTLIST_DATA_S] -->
 	<select id="selectFidoBackupInfo" parameterType="com.scbank.process.api.svc.common.dao.dto.FidoBackupInfoParameter" resultType="com.scbank.process.api.svc.common.dao.dto.FidoBackupInfoResult" >
		SELECT 
			  USER_ID
			, TR_ID
			, TELE_TYPE
			, HP_NUM
			, RESLT_CD
		FROM 
			FIDODBS01.OP_MYSELF_CONFR_HIST
		WHERE USER_ID = #{userId}
		AND TR_ID = #{trId}
		AND HP_NUM = #{hpNum}
		WITH UR
	</select>
	
</mapper>