<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.common.dao.TblBranchDao">
	<select id="selectBranchName" parameterType="java.util.List" resultType = "com.scbank.process.api.svc.common.dao.dto.BranchNameResult">
		SELECT
			BRNCH_CD AS BRANCH_CD,
			FLDBRNAME AS BRANCH_NAME
		FROM
			TBLBRANCH
		WHERE
			BRNCH_MK = '1'
			<if test="branchCodes != null">
				AND BRNCH_CD IN
				<foreach collection="branchCodes" item="item" open="(" close=")" separator=",">
					#{item}
				</foreach>
			</if>
		WITH UR
	</select>
</mapper>