<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.scbank.process.api.svc.common.dao.SubCdDao">

    <!-- 서비스 동의 항목 및 툴팁 정보 조회 -->
	<select id="selectPushServiceCd" resultType = "com.scbank.process.api.svc.common.dao.dto.SelectPushServiceCdResult">
	SELECT
        CMMN_CD,
        SUB_CD,
        CD_NM,
        EXPLN,
        USE_IND
    FROM UIDBS01.SUB_CD
    WHERE CMMN_CD IN ('RM7', 'RM8')
        AND USE_IND='Y'
	</select>


</mapper>